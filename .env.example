# ===================================
# Dallo DevSecOps 환경 변수 설정
# ===================================
# 이 파일을 .env로 복사하여 사용하세요:
#   cp .env.example .env

# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPOSITORY=owner/dallo-devsecops

# --- SonarQube ---
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=sqp_xxxxxxxxxxxxxxxxxxxx
SONAR_PROJECT_KEY=dallo-devsecops

# --- LLM API (박영주 담당 모듈에서 사용) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# --- PostgreSQL (임해안 담당 DB) ---
DATABASE_URL=postgresql://sonar:sonar_password@localhost:5432/dallo_db
